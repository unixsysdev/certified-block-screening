# LaTeX build artefacts. main.pdf is NOT ignored: CI rebuilds and commits it
# back so the rendered paper is always visible in paper/main.pdf on main.
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz
